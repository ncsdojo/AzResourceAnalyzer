#Requires -Version 7.0

$script:_ArModuleRoot = $PSScriptRoot

. "$PSScriptRoot/Classes/ArTokenStore.ps1"

foreach ($file in (Get-ChildItem "$PSScriptRoot/Private/*.ps1" -ErrorAction SilentlyContinue | Sort-Object Name)) {
    . $file.FullName
}

foreach ($file in (Get-ChildItem "$PSScriptRoot/Public/*.ps1" -ErrorAction SilentlyContinue | Sort-Object Name)) {
    . $file.FullName
}

# Constrained Language Mode check
if ($ExecutionContext.SessionState.LanguageMode -eq 'ConstrainedLanguage') {
    Write-Warning "Constrained Language Mode detected. Module loaded but some .NET operations may be blocked.`nTo resolve: sign all .ps1 files with a trusted code-signing certificate, or deploy to a WDAC-trusted path."
}

# Tab completion for Invoke-ArExport -Collector
$script:_ArCollectorList = @('All') + @(
    Get-ChildItem "$PSScriptRoot/Collectors" -Filter '*.ps1' -Recurse -ErrorAction SilentlyContinue |
        ForEach-Object { $_.BaseName } | Sort-Object -Unique
)

Register-ArgumentCompleter -CommandName 'Invoke-ArExport' -ParameterName 'Collector' -ScriptBlock {
    param($commandName, $parameterName, $wordToComplete, $commandAst, $fakeBoundParameters)
    & (Get-Module AzResourceAnalyzer) { $script:_ArCollectorList } |
        Where-Object { $_ -like "$wordToComplete*" } |
        ForEach-Object { [System.Management.Automation.CompletionResult]::new($_, $_, 'ParameterValue', $_) }
}

